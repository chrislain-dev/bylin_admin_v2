# ========================================
# 📋 Configuration Template
# ========================================
# Copie ce fichier en .env et remplis les valeurs

# ========================================
# 🌐 API Configuration
# ========================================
NUXT_PUBLIC_API_URL=http://localhost:8000
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_PUBLIC_STOREFRONT_URL=http://localhost:3001

# ========================================
# 🔐 Sanctum Configuration
# ========================================
NUXT_SANCTUM_BASE_URL=http://localhost:8000

# ========================================
# 🎨 Application
# ========================================
NUXT_PUBLIC_APP_NAME="Bylin Admin"
NODE_ENV=development

# ========================================
# 📊 Analytics (optionnel)
# ========================================
# NUXT_PUBLIC_GA_ID=
# NUXT_PUBLIC_SENTRY_DSN=

# ========================================
# 🔧 Debug & Logs
# ========================================
NUXT_PUBLIC_DEBUG=false
NUXT_PUBLIC_API_DEBUG=false
